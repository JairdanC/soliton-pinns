


import torch
import torch.nn as nn
import matplotlib.pyplot as plt
import numpy as np
import gc
import pickle

import sys
from pathlib import Path

# Add parent directory to path
sys.path.append(str(Path.cwd().parent))

from models import KDV


cuda_available = torch.cuda.is_available()
print(f"CUDA available: {cuda_available}")
testing_seeds = [42, 72, 83, 27, 81]





testing_indices_1 = [0, 1, 2, 5, 10, 25, 50, 100, 200, 300, 500, 750, 1000]

experiment_results_1_soliton = []

print("Starting 1-Soliton Experiment...")

for testing_val in testing_indices_1:
    results = {
        'time': [],
        'mae': [],
        'max_error': []
    }
    
    for current_seed in testing_seeds:
        INIT_PARAMS = dict(
            num_solitons             = 1,
            n_hidden_layers          = 4, 
            n_neurons_per_layer      = 32, 
            activation               = nn.Tanh,
            seed                     = current_seed, 
            verbose                  = False,
        )
        
        TRAIN_PARAMS = dict(
            adam_epochs              = 1000,
            verbose_step             = 100,
            n_collocation            = 50000, 
            n_initial                = 30000,  
            n_boundary               = 10000,
            n_energy                 = testing_val,
            w_ic                     = 5.0,    
            w_bc                     = 1.0,    
            w_pde                    = 15.0,   
            adam_lr                  = 1e-3,   
            lbfgs_lr                 = 1.0,    
            lbfgs_history_size       = 100,    
            adaptive_sampling        = False,   
        )
    
        model = KDV(INIT_PARAMS)
        model.train(TRAIN_PARAMS)
        mae, max_err = model.test(plot_heatmap=False)

        print(f"  -> Integrals: {testing_val:<4} | Seed: {current_seed:<4} | Time: {model.training_time:6.2f} s | MAE: {mae:.6e}")

        results['time'].append(model.training_time)
        results['mae'].append(mae)
        results['max_error'].append(max_err)
        
        # Explicitly free up GPU memory
        del model
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()
        
    experiment_results_1_soliton.append({
        'n_energy': testing_val,
        'time_mean': float(np.mean(results['time'])),
        'time_std': float(np.std(results['time'])),
        'mae_mean': float(np.mean(results['mae'])),
        'mae_std': float(np.std(results['mae'])),
        'raw_data': results
    })
    
    # Save a backup to disk
    with open('1_soliton_backup.pkl', 'wb') as f:
        pickle.dump(experiment_results_1_soliton, f)
    
    print(f"=== Finished n_energy={testing_val} | Avg MAE: {experiment_results_1_soliton[-1]['mae_mean']:.6e} ===\n")
        
print("1 Soliton Experiment OVER!")





testing_indices_2 = [0, 1, 2, 5, 10, 25, 50, 100, 200, 300, 500]

experiment_results_2_soliton = []

print("Starting 2-Soliton Experiment...")

for testing_val in testing_indices_2:
    results = {
        'time': [],
        'mae': [],
        'max_error': []
    }
    
    for current_seed in testing_seeds:
        INIT_PARAMS = dict(
            num_solitons=2,
            n_hidden_layers=7, 
            n_neurons_per_layer=62, 
            activation=nn.Tanh,
            seed=current_seed, 
            verbose=False,
        )
        
        TRAIN_PARAMS = dict(
            adam_epochs=1000,
            verbose_step=100,
            n_collocation=100000, 
            n_initial=10000,  
            n_boundary=10000, 
            n_energy=testing_val,
            w_ic=10.0,    
            w_bc=1.0,    
            w_pde=100.0,   
            adam_lr=1e-3,   
            lbfgs_lr=2.0,    
            lbfgs_history_size=100, 
            adaptive_sampling=False,   
            lbfgs_version='old'
        )
    
        model = KDV(INIT_PARAMS)
        model.train(TRAIN_PARAMS)
        mae, max_err = model.test(plot_heatmap=False)

        print(f"  -> Integrals: {testing_val:<4} | Seed: {current_seed:<4} | Time: {model.training_time:6.2f} s | MAE: {mae:.6e}")

        results['time'].append(model.training_time)
        results['mae'].append(mae)
        results['max_error'].append(max_err)
        
        # Explicitly free up GPU memory before the next seed starts
        del model
        gc.collect()
        if torch.cuda.is_available():
            torch.cuda.empty_cache()
        
    experiment_results_2_soliton.append({
        'n_energy': testing_val,
        'time_mean': float(np.mean(results['time'])),
        'time_std': float(np.std(results['time'])),
        'mae_mean': float(np.mean(results['mae'])),
        'mae_std': float(np.std(results['mae'])),
        'raw_data': results
    })
    
    # Save a backup to disk just in case it crashes overnight
    with open('2_soliton_backup.pkl', 'wb') as f:
        pickle.dump(experiment_results_2_soliton, f)
    
    print(f"=== Finished n_energy={testing_val} | Avg MAE: {experiment_results_2_soliton[-1]['mae_mean']:.6e} ===\n")
        
print("2 Soliton Experiment OVER!")





#Import pickled data object
with open('1_soliton_backup.pkl', 'rb') as f:
    soliton_1_raw = pickle.load(f) #this is a list of the dicts of the experimental results, see above experiments for keys

n_energy = []
avg_mae = []
std_mae = []
avg_time = []
std_time = []
avg_max_err = [] #average between groups, of max within groups (groups = n_energy, where each seed is a different result)
max_max_err = [] #max between groups
std_max_err = []

#Reconstructing usable experiment data
print("Loaded Experiment Results:\n") #formatting
for result in soliton_1_raw:
    n_energy.append(result['n_energy'])
    avg_mae.append(result['mae_mean'])
    std_mae.append(result['mae_std'])
    avg_time.append(result['time_mean'])
    std_time.append(result['time_std'])
    avg_max_err.append(np.mean(result['raw_data']['max_error']))
    max_max_err.append(np.max(result['raw_data']['max_error']))
    std_max_err.append(np.std(result['raw_data']['max_error']))
    #printing out values
    print(f'n_energy: {result['n_energy']:<4} | Avg MAE: {result['mae_mean']:.6e} | Avg Time: {result['time_mean']:.2e}s | Avg Max Error: {np.mean(result['raw_data']['max_error']):.6e}')
    print(f'---------------| Std MAE: {result['mae_std']:.6e} | Std Time: {result['time_std']:.2e}s | Std Max Error: {np.std(result['raw_data']['max_error']):.6e}')





plt.errorbar(n_energy, avg_time, yerr=std_time, color='firebrick', marker='o')
plt.xlabel('Number of Energy Points (n_energy)')
plt.ylabel('Mean Time (s)')
plt.title('Training Time vs. Energy Points')
plt.grid(True)
plt.show()





#Mean Error
fig, ax = plt.subplots(2, 1)
ax1, ax2 = ax
ax1.errorbar(n_energy, avg_mae, yerr=std_mae, color='seagreen', fmt='o')
ax1.set(xscale='log', xlabel='Log [Number of Energy Points (n_energy)]', ylabel='Mean Error')
ax1.grid(True)
ax2.plot(n_energy, avg_max_err, marker='o', color='lightseagreen')
ax2.set(xscale='log', xlabel='Log [Number of Energy Points (n_energy)]', ylabel='Max Error')
ax2.grid(True)
fig.suptitle('Error Metrics vs. Energy Points')
plt.show()





plt.errorbar(avg_time, avg_mae, xerr=std_time, yerr=std_mae, color='mediumorchid', marker='o', linestyle='None')
plt.xlabel('Time (s)')
plt.ylabel('Mean Time (s)')
plt.title('Training Time vs. Energy Points')
plt.grid(True)
plt.show()





